 //! behavior easier to review without paging through the rest of `chatwidget.rs`.
 
 use super::*;
+use tokio::process::Command;
 
 pub(super) const DEFAULT_TERMINAL_TITLE_ITEMS: [&str; 2] = ["spinner", "project"];
 pub(super) const TERMINAL_TITLE_SPINNER_FRAMES: [&str; 10] =
     ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"];
 pub(super) const TERMINAL_TITLE_SPINNER_INTERVAL: Duration = Duration::from_millis(100);
+const STATUS_LINE_COMMAND_TIMEOUT: Duration = Duration::from_millis(150);
+const STATUS_LINE_COMMAND_MAX_CHARS: usize = 220;
+
+fn sanitize_status_line_command_output(text: &str) -> Option<String> {
+    let line = text.lines().map(str::trim).find(|line| !line.is_empty())?;
+    if line.chars().count() <= STATUS_LINE_COMMAND_MAX_CHARS {
+        return Some(line.to_string());
+    }
+
+    let truncated = line
+        .chars()
+        .take(STATUS_LINE_COMMAND_MAX_CHARS.saturating_sub(1))
+        .collect::<String>();
+    Some(format!("{truncated}…"))
+}
+
+async fn run_status_line_command(command_text: &str, cwd: &Path) -> Option<String> {
+    let mut command = if cfg!(windows) {
+        let mut cmd = Command::new("cmd");
+        cmd.arg("/C").arg(command_text);
+        cmd
+    } else {
+        let mut cmd = Command::new("sh");
+        cmd.arg("-lc").arg(command_text);
+        cmd
+    };
+    command.current_dir(cwd);
+    command.stdout(std::process::Stdio::piped());
+    command.stderr(std::process::Stdio::null());
+
+    let output = match tokio::time::timeout(STATUS_LINE_COMMAND_TIMEOUT, command.output()).await {
+        Ok(Ok(output)) => output,
+        _ => return None,
+    };
+    if !output.status.success() {
+        return None;
+    }
+
+    sanitize_status_line_command_output(&String::from_utf8_lossy(&output.stdout))
+}
 
